{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"extends": [
		"./node_modules/ultracite/config/oxlint/core/.oxlintrc.json",
		"./node_modules/ultracite/config/oxlint/react/.oxlintrc.json",
		"./node_modules/ultracite/config/oxlint/next/.oxlintrc.json"
	],
	"rules": {
		"func-style": "off",
		"no-plusplus": "off",
		"no-empty": "off",
		"no-empty-function": "off",
		"no-bitwise": "off",
		"no-shadow": "off",
		"no-eq-null": "off",
		"no-void": "off",
		"no-nested-ternary": "off",
		"no-negated-condition": "off",
		"no-duplicate-imports": "off",
		"no-promise-executor-return": "off",
		"prefer-destructuring": "off",
		"prefer-template": "off",
		"no-use-before-define": "off",
		"require-await": "off",
		"sort-keys": "off",
		"default-case": "off",
		"complexity": "off",
		"jsdoc/check-param-names": "off",
		"jsdoc/require-param": "off",
		"jsdoc/require-returns": "off",
		"jsdoc/require-param-description": "off",
		"jsdoc/require-returns-description": "off",
		"jsdoc/require-property-type": "off",
		"react-perf/jsx-no-new-object-as-prop": "off",
		"react-perf/jsx-no-new-array-as-prop": "off",
		"react-perf/jsx-no-new-function-as-prop": "off",
		"react-perf/jsx-no-jsx-as-prop": "off",
		"react/no-danger": "off",
		"react/no-unescaped-entities": "off",
		"react/no-array-index-key": "off",
		"react/jsx-no-useless-fragment": "off",
		"react/jsx-no-constructed-context-values": "warn",
		"react/iframe-missing-sandbox": "warn",
		"jsx-a11y/heading-has-content": "off",
		"unicorn/numeric-separators-style": "off",
		"unicorn/no-nested-ternary": "off",
		"unicorn/prefer-add-event-listener": "off",
		"unicorn/consistent-function-scoping": "off",
		"unicorn/no-await-expression-member": "off",
		"unicorn/no-array-for-each": "off",
		"unicorn/no-array-reduce": "off",
		"unicorn/no-new-array": "off",
		"unicorn/new-for-builtins": "off",
		"unicorn/prefer-ternary": "off",
		"unicorn/prefer-response-static-json": "off",
		"unicorn/prefer-query-selector": "off",
		"unicorn/prefer-dom-node-remove": "off",
		"unicorn/prefer-array-index-of": "off",
		"unicorn/prefer-math-trunc": "off",
		"unicorn/prefer-includes": "off",
		"unicorn/prefer-array-find": "off",
		"unicorn/no-useless-spread": "off",
		"unicorn/no-useless-collection-argument": "off",
		"unicorn/no-lonely-if": "off",
		"unicorn/no-instanceof-builtins": "off",
		"unicorn/no-immediate-mutation": "off",
		"promise/prefer-await-to-then": "off",
		"promise/prefer-await-to-callbacks": "off",
		"promise/avoid-new": "off",
		"promise/no-return-wrap": "off",
		"promise/no-callback-in-promise": "off",
		"import/no-duplicates": "off",
		"typescript/no-non-null-assertion": "off",
		"typescript/no-invalid-void-type": "off",
		"typescript/no-inferrable-types": "off",
		"typescript/consistent-type-imports": "off",
		"typescript/prefer-for-of": "off",
		"nextjs/no-assign-module-variable": "off"
	}
}
